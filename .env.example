# --- Database ----------------------------------------------------------------
# Padrão: Postgres do docker-compose (porta 5432 exposta no host).
# Para rodar o app fora do container apontando pro Postgres do compose, use a URL abaixo
# trocando "user:pass" pelos valores de POSTGRES_USER/POSTGRES_PASSWORD logo abaixo.
# Para usar SQLite local (sem Docker), descomente a linha SQLite e comente a Postgres.
# DATABASE_URL=sqlite:///data/consulta_cnpj.db
DATABASE_URL=postgresql://user:pass@localhost:5432/consulta_cnpj

# --- Postgres (usado pelo docker-compose) ------------------------------------
# Variáveis lidas pelo docker-compose para provisionar o Postgres e
# montar a DATABASE_URL usada pelo app dentro do container (via service "db").
# Gere uma senha forte com:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=consulta
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=consulta_cnpj

# --- Automation (Chrome + PyAutoGUI) -----------------------------------------
CHROME_HEADLESS=true

# Deixe vazio para detectar automaticamente; defina caso Chrome/ChromeDriver
# estejam em caminhos não padrão.
CHROME_BINARY_PATH=

# Número máximo de instâncias do navegador em paralelo
MAX_WORKERS=1

# Delay entre requisições consecutivas (segundos) – ajuda a evitar rate limit
REQUEST_DELAY_SECONDS=2.0

# Configuração de retry
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=60
PAGE_LOAD_TIMEOUT_SECONDS=30

# --- Export ------------------------------------------------------------------
EXPORT_DIR=exports

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/consulta_cnpj.log