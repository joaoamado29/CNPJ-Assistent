# --- Database ----------------------------------------------------------------
# SQLite (default) or PostgreSQL connection string
# DATABASE_URL=sqlite:///data/agente_telegram.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/agente_telegram
DATABASE_URL=sqlite:///data/agente_telegram.db

# --- Postgres (only used when running via docker-compose) --------------------
# These variables are read by docker-compose to provision the Postgres service
# and build the DATABASE_URL the bot uses inside the container.
# CHANGE THE PASSWORD before deploying anywhere shared.
POSTGRES_USER=agente
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=agente_telegram

# --- Automation (BotCity / Chrome) -------------------------------------------
CHROME_HEADLESS=true

# Leave empty to auto-detect; set if Chrome/ChromeDriver are in non-standard paths
CHROME_BINARY_PATH=

# Maximum concurrent browser instances
MAX_WORKERS=

# Delay between consecutive requests (seconds) – helps avoid rate limiting
REQUEST_DELAY_SECONDS=2.0

# Retry configuration
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=60
PAGE_LOAD_TIMEOUT_SECONDS=30

# --- Export ------------------------------------------------------------------
EXPORT_DIR=exports

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/agente_telegram.log
