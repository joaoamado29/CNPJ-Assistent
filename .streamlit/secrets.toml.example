# Modelo de configuração de login OIDC do Streamlit (st.login / st.user).
# Copie para .streamlit/secrets.toml e preencha com suas credenciais do Google Cloud.
#   copy .streamlit\secrets.toml.example .streamlit\secrets.toml   (Windows)
#   cp   .streamlit/secrets.toml.example .streamlit/secrets.toml   (Linux/macOS)
#
# Credenciais: Google Cloud Console -> APIs e Serviços -> Clientes -> ID do cliente OAuth (Aplicativo da Web).
# A URI de redirecionamento cadastrada no Google deve ser IDÊNTICA ao redirect_uri abaixo.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
# Gere uma string aleatória longa, ex.: python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "TROQUE_POR_UMA_STRING_ALEATORIA_LONGA"
client_id = "COLE_AQUI_SEU_CLIENT_ID"
client_secret = "COLE_AQUI_SEU_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[deepseek]
# API key criada em https://platform.deepseek.com (API keys → Create new API key)
# Formato: sk-...
api_key = "COLE_AQUI_SUA_API_KEY_DEEPSEEK"
